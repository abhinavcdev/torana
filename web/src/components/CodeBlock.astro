---
interface Props {
  label: string;
  copy: string;
  span?: boolean;
}
const { label, copy, span = false } = Astro.props;
---

<div class:list={["code-card", { "install-span": span }]}>
  <div class="code-head">
    <span>{label}</span>
    <button class="copy-btn" data-copy={copy} type="button">copy</button>
  </div>
  <pre><slot /></pre>
</div>

<script>
  document.querySelectorAll<HTMLButtonElement>(".copy-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const text = btn.getAttribute("data-copy") ?? "";
      navigator.clipboard.writeText(text).then(() => {
        const prev = btn.textContent;
        btn.textContent = "copied";
        setTimeout(() => {
          btn.textContent = prev;
        }, 1400);
      });
    });
  });
</script>
