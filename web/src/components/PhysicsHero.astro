<div class="flow-stage wrap">
  <div class="flow-frame">
    <canvas id="flow" aria-label="Animation: requests flowing from clients through the torana gate, splitting across three weighted upstreams"></canvas>
    <div class="flow-readout" aria-hidden="true">
      <span class="flow-count" id="flow-count">0</span>
      <span class="flow-count-label">requests routed live</span>
    </div>
  </div>
  <div class="flow-caption">Weighted round robin at 60 / 30 / 10. Move your cursor to bend the flow, click for a burst.</div>
</div>

<script>
  (function () {
    "use strict";

    const canvas = document.getElementById("flow") as HTMLCanvasElement | null;
    const countEl = document.getElementById("flow-count");
    if (!canvas || !countEl) return;
    const ctx = canvas.getContext("2d");
    if (!ctx) return;
    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    let W = 0, H = 0, DPR = 1;
    let theme = { ink: "", muted: "", line: "", accent: "", accentInk: "", surface: "", ground: "" };

    function readTheme() {
      const cs = getComputedStyle(document.documentElement);
      theme = {
        ink: cs.getPropertyValue("--ink").trim(),
        muted: cs.getPropertyValue("--muted").trim(),
        line: cs.getPropertyValue("--line").trim(),
        accent: cs.getPropertyValue("--accent-bright").trim(),
        accentInk: cs.getPropertyValue("--accent-ink").trim(),
        surface: cs.getPropertyValue("--surface").trim(),
        ground: cs.getPropertyValue("--ground").trim(),
      };
    }
    readTheme();
    window.matchMedia("(prefers-color-scheme: dark)").addEventListener("change", readTheme);
    new MutationObserver(readTheme).observe(document.documentElement, { attributes: true, attributeFilter: ["data-theme"] });

    function resize() {
      DPR = Math.min(window.devicePixelRatio || 1, 2);
      W = canvas!.clientWidth;
      H = canvas!.clientHeight;
      canvas!.width = W * DPR;
      canvas!.height = H * DPR;
      ctx!.setTransform(DPR, 0, 0, DPR, 0, 0);
      layout();
    }

    type Node = {
      x: number; y: number; cardH: number; pulse: number;
      label: string; pct: string;
      c1x: number; c1y: number; c2x: number; c2y: number;
    };
    let gate = { x: 0, y: 0, half: 0 };
    const WEIGHTS = [0.6, 0.3, 0.1];
    let nodes: Node[] = [];

    function layout() {
      gate = { x: W * 0.4, y: H * 0.52, half: Math.min(56, H * 0.18) };
      const nx = W * 0.87;
      const ys = [H * 0.22, H * 0.52, H * 0.82];
      const labels = ["Upstream 1", "Upstream 2", "Upstream 3"];
      nodes = WEIGHTS.map((w, i) => {
        const y = ys[i];
        const x = nx;
        return {
          x, y,
          cardH: 24 + w * 58,
          pulse: 0,
          label: labels[i],
          pct: Math.round(w * 100) + "%",
          c1x: gate.x + (x - gate.x) * 0.42, c1y: gate.y,
          c2x: gate.x + (x - gate.x) * 0.78, c2y: y,
        };
      });
    }

    function pickNode() {
      const r = Math.random();
      return r < WEIGHTS[0] ? 0 : r < WEIGHTS[0] + WEIGHTS[1] ? 1 : 2;
    }

    function cubic(p0: number, p1: number, p2: number, p3: number, t: number) {
      const mt = 1 - t;
      return mt * mt * mt * p0 + 3 * mt * mt * t * p1 + 3 * mt * t * t * p2 + t * t * t * p3;
    }

    const U_GATE = 0.42;

    type Particle = {
      spawnY: number; node: number; u: number; speed: number;
      c1x: number; c1y: number; c2x: number; c2y: number;
      jx: number; jy: number; jvx: number; jvy: number;
      trail: { x: number; y: number }[];
    };
    let particles: Particle[] = [];
    const MAX_P = 42;
    const mouse = { x: -9999, y: -9999 };
    let parallaxX = 0, parallaxY = 0;
    let routed = 0;
    let pings: { t: number }[] = [];

    function spawn(startU?: number): Particle {
      const spawnY = H * (0.12 + 0.76 * Math.random());
      return {
        spawnY,
        node: pickNode(),
        u: startU ?? 0,
        speed: 0.0068 + Math.random() * 0.0026,
        c1x: gate.x * 0.3, c1y: spawnY,
        c2x: gate.x * 0.74, c2y: gate.y + (spawnY - gate.y) * 0.16,
        jx: 0, jy: 0, jvx: 0, jvy: 0,
        trail: [],
      };
    }
    function fillParticles() {
      particles = [];
      for (let i = 0; i < MAX_P; i++) particles.push(spawn(Math.random() * U_GATE * 0.9));
    }

    function basePoint(p: Particle) {
      if (p.u < U_GATE) {
        const t = p.u / U_GATE;
        return {
          x: cubic(-10, p.c1x, p.c2x, gate.x, t),
          y: cubic(p.spawnY, p.c1y, p.c2y, gate.y, t),
        };
      }
      const n = nodes[p.node];
      const t = (p.u - U_GATE) / (1 - U_GATE);
      return {
        x: cubic(gate.x, n.c1x, n.c2x, n.x, t),
        y: cubic(gate.y, n.c1y, n.c2y, n.y, t),
      };
    }

    let t = 0;
    function step() {
      t += 0.016;

      parallaxX += ((mouse.x > -9000 ? ((mouse.x - W / 2) / W) * 10 : 0) - parallaxX) * 0.06;
      parallaxY += ((mouse.y > -9000 ? ((mouse.y - H / 2) / H) * 8 : 0) - parallaxY) * 0.06;

      for (let i = particles.length - 1; i >= 0; i--) {
        const p = particles[i];
        const wasBeforeGate = p.u < U_GATE;
        p.u += p.speed;

        if (wasBeforeGate && p.u >= U_GATE) {
          pings.push({ t: 0 });
        }
        if (p.u >= 1) {
          nodes[p.node].pulse = 1;
          routed++;
          particles[i] = spawn();
          continue;
        }

        const base = basePoint(p);

        const mx = base.x - mouse.x, my = base.y - mouse.y;
        const md2 = mx * mx + my * my;
        if (md2 < 6400 && md2 > 0.01) {
          const md = Math.sqrt(md2);
          const f = (1 - md / 80) * 2.4;
          p.jvx += (mx / md) * f;
          p.jvy += (my / md) * f;
        }
        p.jvx *= 0.88; p.jvy *= 0.88;
        p.jx += p.jvx; p.jy += p.jvy;
        p.jx *= 0.94; p.jy *= 0.94;

        const drawn = { x: base.x + p.jx, y: base.y + p.jy };
        p.trail.push(drawn);
        if (p.trail.length > 7) p.trail.shift();
      }
      for (const n of nodes) n.pulse *= 0.91;
      for (let i = pings.length - 1; i >= 0; i--) {
        pings[i].t += 0.045;
        if (pings[i].t >= 1) pings.splice(i, 1);
      }
    }

    function rr(x: number, y: number, w: number, h: number, r: number) {
      if (w <= 0 || h <= 0) return;
      ctx!.beginPath();
      ctx!.roundRect(x, y, w, h, r);
      ctx!.fill();
    }

    function drawBackdrop() {
      const step = 26;
      ctx!.fillStyle = theme.line;
      ctx!.globalAlpha = 0.4;
      const ox = parallaxX * -0.6, oy = parallaxY * -0.6;
      for (let gx = ((ox % step) + step) % step; gx < W; gx += step) {
        for (let gy = ((oy % step) + step) % step; gy < H; gy += step) {
          ctx!.beginPath();
          ctx!.arc(gx, gy, 1, 0, Math.PI * 2);
          ctx!.fill();
        }
      }
      ctx!.globalAlpha = 1;
    }

    function drawLanes() {
      for (const n of nodes) {
        ctx!.save();
        ctx!.strokeStyle = theme.accent;
        ctx!.lineWidth = Math.max(3, n.cardH * 0.16);
        ctx!.globalAlpha = 0.08;
        ctx!.beginPath();
        ctx!.moveTo(gate.x, gate.y);
        ctx!.bezierCurveTo(n.c1x, n.c1y, n.c2x, n.c2y, n.x, n.y);
        ctx!.stroke();
        ctx!.restore();

        ctx!.save();
        ctx!.strokeStyle = theme.accent;
        ctx!.lineWidth = 1.4;
        ctx!.globalAlpha = 0.5;
        ctx!.setLineDash([2, 9]);
        ctx!.lineDashOffset = reduced ? 0 : -t * 34;
        ctx!.beginPath();
        ctx!.moveTo(gate.x, gate.y);
        ctx!.bezierCurveTo(n.c1x, n.c1y, n.c2x, n.c2y, n.x, n.y);
        ctx!.stroke();
        ctx!.restore();
      }
    }

    function drawGate() {
      const glowR = 70 + Math.sin(t * 1.1) * 6;
      const glow = ctx!.createRadialGradient(gate.x, gate.y, 0, gate.x, gate.y, glowR);
      glow.addColorStop(0, color_mix(theme.accent, 0.22));
      glow.addColorStop(1, color_mix(theme.accent, 0));
      ctx!.fillStyle = glow;
      ctx!.beginPath();
      ctx!.arc(gate.x, gate.y, glowR, 0, Math.PI * 2);
      ctx!.fill();

      const ph = gate.half;
      const beamGrad = ctx!.createLinearGradient(gate.x - 40, 0, gate.x + 40, 0);
      beamGrad.addColorStop(0, theme.accentInk);
      beamGrad.addColorStop(0.5, theme.accent);
      beamGrad.addColorStop(1, theme.accentInk);
      ctx!.fillStyle = beamGrad;
      rr(gate.x - 40, 10, 80, 7.5, 3.5);
      rr(gate.x - 30, 24, 60, 5.5, 2.75);

      ctx!.fillStyle = theme.ink;
      ctx!.globalAlpha = 0.85;
      rr(gate.x - 3.5, 38, 7, Math.max(0, gate.y - ph - 38), 3);
      rr(gate.x - 3.5, gate.y + ph, 7, Math.max(0, H - 30 - (gate.y + ph)), 3);
      ctx!.globalAlpha = 1;

      for (const ping of pings) {
        ctx!.strokeStyle = theme.accent;
        ctx!.globalAlpha = (1 - ping.t) * 0.5;
        ctx!.lineWidth = 1.5;
        ctx!.beginPath();
        ctx!.arc(gate.x, gate.y, 10 + ping.t * 46, 0, Math.PI * 2);
        ctx!.stroke();
        ctx!.globalAlpha = 1;
      }

      ctx!.fillStyle = theme.muted;
      ctx!.font = "600 10.5px ui-monospace, Menlo, monospace";
      ctx!.textAlign = "center";
      ctx!.letterSpacing = "0.04em";
      ctx!.fillText("TORANA", gate.x, H - 12);
      ctx!.letterSpacing = "0px";
    }

    function color_mix(hex: string, alpha: number) {
      const h = hex.replace("#", "");
      if (h.length !== 6) return hex;
      const r = parseInt(h.slice(0, 2), 16), g = parseInt(h.slice(2, 4), 16), b = parseInt(h.slice(4, 6), 16);
      return `rgba(${r}, ${g}, ${b}, ${alpha})`;
    }

    function drawNodes() {
      for (const n of nodes) {
        const w = 46, h = n.cardH;
        const x0 = n.x - w / 2, y0 = n.y - h / 2;

        if (n.pulse > 0.04) {
          ctx!.strokeStyle = theme.accent;
          ctx!.globalAlpha = n.pulse * 0.7;
          ctx!.beginPath();
          ctx!.roundRect(x0 - 5 * n.pulse, y0 - 5 * n.pulse, w + 10 * n.pulse, h + 10 * n.pulse, 10);
          ctx!.stroke();
          ctx!.globalAlpha = 1;
        }

        ctx!.save();
        ctx!.shadowColor = color_mix(theme.ink, 0.16);
        ctx!.shadowBlur = 10;
        ctx!.shadowOffsetY = 3;
        ctx!.fillStyle = theme.surface;
        ctx!.beginPath();
        ctx!.roundRect(x0, y0, w, h, 8);
        ctx!.fill();
        ctx!.restore();

        ctx!.strokeStyle = theme.line;
        ctx!.lineWidth = 1;
        ctx!.beginPath();
        ctx!.roundRect(x0, y0, w, h, 8);
        ctx!.stroke();

        ctx!.fillStyle = theme.accent;
        rr(x0, y0, 4, h, 2);

        ctx!.fillStyle = theme.ink;
        ctx!.font = "700 12px ui-monospace, Menlo, monospace";
        ctx!.textAlign = "center";
        ctx!.fillText(n.pct, n.x + 2, n.y + 4);

        ctx!.fillStyle = theme.muted;
        ctx!.font = "10px ui-monospace, Menlo, monospace";
        ctx!.fillText(n.label, n.x, n.y + h / 2 + 15);
      }
    }

    function draw() {
      ctx!.clearRect(0, 0, W, H);
      drawBackdrop();
      drawLanes();

      for (const p of particles) {
        for (let j = 1; j < p.trail.length; j++) {
          ctx!.strokeStyle = theme.accent;
          ctx!.globalAlpha = (j / p.trail.length) * 0.35;
          ctx!.lineWidth = 2;
          ctx!.beginPath();
          ctx!.moveTo(p.trail[j - 1].x, p.trail[j - 1].y);
          ctx!.lineTo(p.trail[j].x, p.trail[j].y);
          ctx!.stroke();
        }
        ctx!.globalAlpha = 1;
        const last = p.trail[p.trail.length - 1];
        if (last) {
          ctx!.save();
          ctx!.shadowColor = theme.accent;
          ctx!.shadowBlur = 8;
          ctx!.fillStyle = theme.accent;
          ctx!.beginPath();
          ctx!.arc(last.x, last.y, 2.8, 0, Math.PI * 2);
          ctx!.fill();
          ctx!.restore();
        }
      }

      drawGate();
      drawNodes();

      ctx!.fillStyle = theme.muted;
      ctx!.font = "10.5px ui-monospace, Menlo, monospace";
      ctx!.textAlign = "left";
      ctx!.fillText("clients", 8, H - 12);
    }

    let frameSkip = 0;
    function updateCounter() {
      countEl!.textContent = routed.toLocaleString("en-US");
    }

    let running = false, rafId = 0;
    function loop() {
      step();
      draw();
      if (++frameSkip % 6 === 0) updateCounter();
      rafId = requestAnimationFrame(loop);
    }
    function start() { if (!running && !reduced) { running = true; rafId = requestAnimationFrame(loop); } }
    function stop() { running = false; cancelAnimationFrame(rafId); }

    canvas.addEventListener("pointermove", (e) => {
      const r = canvas.getBoundingClientRect();
      mouse.x = e.clientX - r.left;
      mouse.y = e.clientY - r.top;
    });
    canvas.addEventListener("pointerleave", () => { mouse.x = -9999; mouse.y = -9999; });
    canvas.addEventListener("click", () => {
      for (let i = 0; i < 10 && particles.length < 80; i++) particles.push(spawn(Math.random() * 0.08));
    });

    document.addEventListener("visibilitychange", () => {
      if (document.hidden) stop(); else start();
    });
    new IntersectionObserver((entries) => {
      entries.forEach((en) => { if (en.isIntersecting) start(); else stop(); });
    }).observe(canvas);

    window.addEventListener("resize", () => {
      resize();
      if (reduced) { draw(); }
    });
    resize();
    fillParticles();
    if (reduced) {
      for (let i = 0; i < 200; i++) step();
      draw();
      updateCounter();
    } else {
      start();
    }
  })();
</script>
